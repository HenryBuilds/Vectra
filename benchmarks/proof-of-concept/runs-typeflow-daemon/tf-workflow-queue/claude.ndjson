{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QXZnoEQsf1R5pCXEQkgQqd","type":"tool_result","content":"1\timport { Queue, Job } from \"bullmq\";\n2\timport { getRedisConnection } from \"./connection\";\n3\timport { WorkflowJobData, WorkflowJobResult, JobState } from \"./types\";\n4\t\n5\tconst QUEUE_NAME = \"workflow-queue\";\n6\t\n7\tlet workflowQueue: Queue<WorkflowJobData, WorkflowJobResult> | null = null;\n8\t\n9\texport function getWorkflowQueue(): Queue<WorkflowJobData, WorkflowJobResult> {\n10\t  if (workflowQueue) {\n11\t    return workflowQueue;\n12\t  }\n13\t\n14\t  const connection = getRedisConnection();\n15\t\n16\t  workflowQueue = new Queue<WorkflowJobData, WorkflowJobResult>(QUEUE_NAME, {\n17\t    connection,\n18\t    defaultJobOptions: {\n19\t      attempts: 3,\n20\t      backoff: {\n21\t        type: \"exponential\",\n22\t        delay: 2000,\n23\t      },\n24\t      removeOnComplete: {\n25\t        age: 24 * 3600, // Keep completed jobs for 24 hours\n26\t        count: 1000, // Keep max 1000 completed jobs\n27\t      },\n28\t      removeOnFail: {\n29\t        age: 7 * 24 * 3600, // Keep failed jobs for 7 days\n30\t      },\n31\t    },\n32\t  });\n33\t\n34\t  return workflowQueue;\n35\t}\n36\t\n37\texport interface AddWorkflowJobOptions {\n38\t  priority?: number;\n39\t  delay?: number;\n40\t  jobId?: string;\n41\t}\n42\t\n43\texport async function addWorkflowJob(\n44\t  data: WorkflowJobData,\n45\t  options?: AddWorkflowJobOptions\n46\t): Promise<Job<WorkflowJobData, WorkflowJobResult>> {\n47\t  const queue = getWorkflowQueue();\n48\t\n49\t  const job = await queue.add(\"execute-workflow\", data, {\n50\t    jobId: options?.jobId,\n51\t    priority: options?.priority,\n52\t    delay: options?.delay,\n53\t  });\n54\t\n55\t  \n56\t\n57\t  return job;\n58\t}\n59\t\n60\texport async function getJobStatus(\n61\t  jobId: string\n62\t): Promise<{\n63\t  id: string;\n64\t  state: JobState;\n65\t  progress: number;\n66\t  result?: WorkflowJobResult;\n67\t  failedReason?: string;\n68\t  attemptsMade: number;\n69\t  data: WorkflowJobData;\n70\t} | null> {\n71\t  const queue = getWorkflowQueue();\n72\t  const job = await queue.getJob(jobId);\n73\t\n74\t  if (!job) {\n75\t    return null;\n76\t  }\n77\t\n78\t  const state = (await job.getState()) as JobState;\n79\t  const progress = job.progress as number;\n80\t  const failedReason = job.failedReason;\n81\t  const attemptsMade = job.attemptsMade;\n82\t\n83\t  return {\n84\t    id: job.id!,\n85\t    state,\n86\t    progress,\n87\t    result: job.returnvalue,\n88\t    failedReason,\n89\t    attemptsMade,\n90\t    data: job.data,\n91\t  };\n92\t}\n93\t\n94\texport async function getQueueStats(): Promise<{\n95\t  waiting: number;\n96\t  active: number;\n97\t  completed: number;\n98\t  failed: number;\n99\t  delayed: number;\n100\t}> {\n101\t  const queue = getWorkflowQueue();\n102\t\n103\t  const [waiting, active, completed, failed, delayed] = await Promise.all([\n104\t    queue.getWaitingCount(),\n105\t    queue.getActiveCount(),\n106\t    queue.getCompletedCount(),\n107\t    queue.getFailedCount(),\n108\t    queue.getDelayedCount(),\n109\t  ]);\n110\t\n111\t  return {\n112\t    waiting,\n113\t    active,\n114\t    completed,\n115\t    failed,\n116\t    delayed,\n117\t  };\n118\t}\n119\t\n120\texport async function cleanQueue(\n121\t  grace: number = 24 * 3600 * 1000\n122\t): Promise<void> {\n123\t  const queue = getWorkflowQueue();\n124\t  await queue.clean(grace, 1000, \"completed\");\n125\t  await queue.clean(grace * 7, 1000, \"failed\");\n126\t  \n127\t}\n128\t\n129\texport async function closeQueue(): Promise<void> {\n130\t  if (workflowQueue) {\n131\t    await workflowQueue.close();\n132\t    workflowQueue = null;\n133\t  }\n134\t}\n135\t"}]},"parent_tool_use_id":null,"session_id":"ba3f8d14-fd68-455b-8326-537a31879ada","uuid":"6ce61662-08e0-4f6a-9870-7a037647a0b9","timestamp":"2026-05-03T23:10:18.839Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\German Classic\\Desktop\\typeflow\\lib\\queue\\workflow-queue.ts","content":"import { Queue, Job } from \"bullmq\";\nimport { getRedisConnection } from \"./connection\";\nimport { WorkflowJobData, WorkflowJobResult, JobState } from \"./types\";\n\nconst QUEUE_NAME = \"workflow-queue\";\n\nlet workflowQueue: Queue<WorkflowJobData, WorkflowJobResult> | null = null;\n\nexport function getWorkflowQueue(): Queue<WorkflowJobData, WorkflowJobResult> {\n  if (workflowQueue) {\n    return workflowQueue;\n  }\n\n  const connection = getRedisConnection();\n\n  workflowQueue = new Queue<WorkflowJobData, WorkflowJobResult>(QUEUE_NAME, {\n    connection,\n    defaultJobOptions: {\n      attempts: 3,\n      backoff: {\n        type: \"exponential\",\n        delay: 2000,\n      },\n      removeOnComplete: {\n        age: 24 * 3600, // Keep completed jobs for 24 hours\n        count: 1000, // Keep max 1000 completed jobs\n      },\n      removeOnFail: {\n        age: 7 * 24 * 3600, // Keep failed jobs for 7 days\n      },\n    },\n  });\n\n  return workflowQueue;\n}\n\nexport interface AddWorkflowJobOptions {\n  priority?: number;\n  delay?: number;\n  jobId?: string;\n}\n\nexport async function addWorkflowJob(\n  data: WorkflowJobData,\n  options?: AddWorkflowJobOptions\n): Promise<Job<WorkflowJobData, WorkflowJobResult>> {\n  const queue = getWorkflowQueue();\n\n  const job = await queue.add(\"execute-workflow\", data, {\n    jobId: options?.jobId,\n    priority: options?.priority,\n    delay: options?.delay,\n  });\n\n  \n\n  return job;\n}\n\nexport async function getJobStatus(\n  jobId: string\n): Promise<{\n  id: string;\n  state: JobState;\n  progress: number;\n  result?: WorkflowJobResult;\n  failedReason?: string;\n  attemptsMade: number;\n  data: WorkflowJobData;\n} | null> {\n  const queue = getWorkflowQueue();\n  const job = await queue.getJob(jobId);\n\n  if (!job) {\n    return null;\n  }\n\n  const state = (await job.getState()) as JobState;\n  const progress = job.progress as number;\n  const failedReason = job.failedReason;\n  const attemptsMade = job.attemptsMade;\n\n  return {\n    id: job.id!,\n    state,\n    progress,\n    result: job.returnvalue,\n    failedReason,\n    attemptsMade,\n    data: job.data,\n  };\n}\n\nexport async function getQueueStats(): Promise<{\n  waiting: number;\n  active: number;\n  completed: number;\n  failed: number;\n  delayed: number;\n}> {\n  const queue = getWorkflowQueue();\n\n  const [waiting, active, completed, failed, delayed] = await Promise.all([\n    queue.getWaitingCount(),\n    queue.getActiveCount(),\n    queue.getCompletedCount(),\n    queue.getFailedCount(),\n    queue.getDelayedCount(),\n  ]);\n\n  return {\n    waiting,\n    active,\n    completed,\n    failed,\n    delayed,\n  };\n}\n\nexport async function cleanQueue(\n  grace: number = 24 * 3600 * 1000\n): Promise<void> {\n  const queue = getWorkflowQueue();\n  await queue.clean(grace, 1000, \"completed\");\n  await queue.clean(grace * 7, 1000, \"failed\");\n  \n}\n\nexport async function closeQueue(): Promise<void> {\n  if (workflowQueue) {\n    await workflowQueue.close();\n    workflowQueue = null;\n  }\n}\n","numLines":135,"startLine":1,"totalLines":135}}}
