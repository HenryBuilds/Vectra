{
  "name": "vectra-vscode",
  "displayName": "Vectra",
  "description": "Local-first code RAG dispatch to Claude Code",
  "version": "0.4.0",
  "publisher": "vectra",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/HenryBuilds/Vectra.git",
    "directory": "extension/vscode"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "vectra.ask",
        "title": "Vectra: Ask about codebase",
        "category": "Vectra"
      },
      {
        "command": "vectra.askAboutSelection",
        "title": "Vectra: Ask about selection",
        "category": "Vectra"
      },
      {
        "command": "vectra.index",
        "title": "Vectra: Index workspace",
        "category": "Vectra"
      },
      {
        "command": "vectra.newChat",
        "title": "New chat",
        "category": "Vectra",
        "icon": "$(add)"
      },
      {
        "command": "vectra.openChat",
        "title": "Vectra: Open chat",
        "category": "Vectra",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vectra.askAboutSelection",
          "when": "editorHasSelection",
          "group": "1_modification@99"
        }
      ],
      "editor/title": [
        {
          "command": "vectra.openChat",
          "when": "!activeWebviewPanelId || activeWebviewPanelId != 'vectra.chat'",
          "group": "navigation@100"
        },
        {
          "command": "vectra.newChat",
          "when": "activeWebviewPanelId == 'vectra.chat'",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Vectra",
      "properties": {
        "vectra.binary": {
          "type": "string",
          "default": "vectra",
          "markdownDescription": "Path to the `vectra` binary. Defaults to `vectra` on PATH. Set this to an absolute path (e.g. `${userHome}/.local/bin/vectra`) if VS Code's environment does not see your shell PATH."
        },
        "vectra.claudeModel": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "haiku",
            "sonnet",
            "opus"
          ],
          "markdownDescription": "Override the Claude model `vectra ask` invokes. Empty = use whatever is in `.vectra/config.toml` or claude's default."
        },
        "vectra.effort": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "low",
            "medium",
            "high"
          ],
          "markdownDescription": "Thinking budget passed as `--effort`. Empty = use config / claude default."
        },
        "vectra.topK": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "maximum": 50,
          "markdownDescription": "Number of context chunks to surface per ask. 0 = use config / built-in default of 8."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build:host && npm run build:webview",
    "build:host": "tsc -p tsconfig.host.json",
    "build:webview": "esbuild src/webview/index.tsx --bundle --minify --format=iife --target=es2022 --outfile=out/webview.js --jsx=automatic --platform=browser --loader:.css=text",
    "watch": "concurrently \"npm:watch:host\" \"npm:watch:webview\"",
    "watch:host": "tsc -watch -p tsconfig.host.json",
    "watch:webview": "esbuild src/webview/index.tsx --bundle --watch --sourcemap --format=iife --target=es2022 --outfile=out/webview.js --jsx=automatic --platform=browser",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.94.0",
    "@vscode/vsce": "^3.2.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
